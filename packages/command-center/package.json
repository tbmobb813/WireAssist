    "react-dom": "^18.3.1",
    "hono": "^4.7.10",
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.5",
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6"
