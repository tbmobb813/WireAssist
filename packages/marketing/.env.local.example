# Copy to .env.local and fill in your values

# Resend (get API key at resend.com — free tier covers 3k emails/month)
RESEND_API_KEY=re_...
# Optional: Resend audience ID for contact list management
RESEND_AUDIENCE_ID=

# Launch mode: "waitlist" shows email capture, "live" shows buy buttons
NEXT_PUBLIC_LAUNCH_MODE=waitlist

# LemonSqueezy checkout URLs (fill in after creating products at app.lemonsqueezy.com)
NEXT_PUBLIC_LS_URL_SOLO=
NEXT_PUBLIC_LS_URL_OPERATOR=
NEXT_PUBLIC_LS_URL_WORKFORCE=
