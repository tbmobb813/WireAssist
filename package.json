{
  "name": "synqworks-monorepo",
  "version": "0.1.0",
  "description": "SynqWorks monorepo — AI core, Linux assistant, agents, and Command Center",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @synqworks/core build",
    "build:aia": "pnpm --filter ai-assist build",
    "build:admin": "pnpm --filter @synqworks/agent-admin build",
    "build:synqpost-mcp": "pnpm --filter @synqworks/synqpost-mcp build",
    "build:content": "pnpm --filter @synqworks/agent-content build",
    "build:command-center": "pnpm --filter @synqworks/command-center build",
    "dev": "pnpm -r --parallel dev",
    "dev:core": "pnpm --filter @synqworks/core dev",
    "dev:aia": "pnpm --filter ai-assist dev",
    "dev:command-center": "pnpm --filter @synqworks/command-center dev",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @synqworks/core test",
    "test:aia": "pnpm --filter ai-assist test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r clean && rm -rf node_modules pnpm-lock.yaml"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "prettier": "^3.3.3",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.3.0"
}
