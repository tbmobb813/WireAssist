{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@wireassist/core": ["wireassist/core/src"],
      "@wireassist/core/*": ["wireassist/core/src/*"],
      "@wireassist/agent-admin": ["packages/agents/admin/src"],
      "@wireassist/agent-admin/*": ["packages/agents/admin/src/*"],
      "@wireassist/trendpost-mcp": ["packages/trendpost-mcp/src"],
      "@wireassist/trendpost-mcp/*": ["packages/trendpost-mcp/src/*"],
      "@wireassist/agent-content": ["packages/agents/content/src"],
      "@wireassist/agent-content/*": ["packages/agents/content/src/*"],
      "@wireassist/agent-research": ["packages/agents/research/src"],
      "@wireassist/agent-research/*": ["packages/agents/research/src/*"]
    }
  },
  "include": ["wireassist", "packages/agents", "packages/trendpost-mcp", "packages/command-center"],
  "references": [
    { "path": "./wireassist/core" },
    { "path": "./wireassist/aia" },
    { "path": "./packages/agents/admin" },
    { "path": "./packages/trendpost-mcp" },
    { "path": "./packages/agents/content" },
    { "path": "./packages/agents/research" },
    { "path": "./packages/command-center" }
  ]
}
